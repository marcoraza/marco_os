# OpenClaw Gateway connection
VITE_OPENCLAW_HOST=127.0.0.1
VITE_OPENCLAW_PORT=18789
VITE_OPENCLAW_TOKEN=
VITE_OPENCLAW_SECURE=false

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional bridge endpoints used by the UI
VITE_FORM_API_URL=
VITE_FORM_API_TOKEN=
VITE_NOTION_API_URL=
VITE_NOTION_API_TOKEN=
VITE_GATEWAY_URL=http://localhost:18792
VITE_BRIDGE_URL=

# Mission Control service (headless API backend for agent section)
VITE_MC_API_URL=http://127.0.0.1:3000
VITE_MC_API_KEY=

# O runner do MC service reaproveita VITE_BRIDGE_URL e VITE_FORM_API_TOKEN acima.
# Para configuracao completa do MC service, veja apps/marco-os-v2/.env.example

# Launcher do Marco OS V2 (legacy, pode ser removido apos migracao completa)
VITE_MARCO_OS_V2_URL=http://127.0.0.1:3000/
